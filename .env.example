# LLM provider: fake | openai | deepseek | ollama
LLM_PROVIDER=fake
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=

# Embedding provider: fake | openai | bge | ollama
EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL=

# Optional LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ecommerce-cs-agent

# Persistence
CHECKPOINT_DB=.cache/checkpoints.sqlite
LONG_MEMORY_DB=.cache/long_memory.sqlite
CHROMA_DIR=.cache/chroma
