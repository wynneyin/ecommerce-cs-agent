# LLM provider: fake | openai | deepseek | ollama
LLM_PROVIDER=fake
LLM_MODEL=
LLM_API_KEY=
LLM_BASE_URL=

# Real LLM pipeline (ignored when LLM_PROVIDER=fake)
USE_LLM_UNDERSTAND=true
USE_LLM_NLU=true
USE_LLM_THINKING=true
USE_LLM_SYNTHESIS=true
USE_LLM_CONVERSATIONAL=true
USE_LLM_REACT_REFLECT=true
# Plan 阶段由模型决定是否前置联网搜索 web_search（需非 fake LLM；与「联网搜索」口令无关也可触发）
USE_LLM_WEB_TOOL=true

# 终端打印每次 LLM 的请求/响应摘录（uvicorn / streamlit 控制台）；设为 0 关闭
AGENT_LOG_LLM=1

# Embedding provider: fake | openai | bge | ollama
EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL=

# 混合检索：BM25 + 向量 分数融合权重（会自动按和归一化为 1）
RETRIEVAL_VEC_WEIGHT=0.7
RETRIEVAL_BM25_WEIGHT=0.3
# 可选 CrossEncoder 重排（sentence-transformers；留空则关闭。示例：cross-encoder/ms-marco-MiniLM-L-6-v2）
RERANKER_MODEL=

# 联网搜索：填 Tavily API Key（tvly-...）则 web_search 默认走 Tavily；留空则用 DuckDuckGo
# https://www.tavily.com/  社区说明示例：https://agent.csdn.net/683fae0a606a8318e85aece0.html
TAVILY_API_KEY=
# 强制后端：duckduckgo | tavily（tavily 需密钥）；留空则自动（有密钥→Tavily）
WEB_SEARCH_BACKEND=

# Optional LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ecommerce-cs-agent

# Persistence
CHECKPOINT_DB=.cache/checkpoints.sqlite
LONG_MEMORY_DB=.cache/long_memory.sqlite
CHROMA_DIR=.cache/chroma
