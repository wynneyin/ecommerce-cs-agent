# 复制到 /etc/systemd/system/ecommerce-agent.service
# 假设代码在 /opt/ecommerce-cs-agent，venv 已创建并已 pip install -r requirements.txt
#
# sudo systemctl daemon-reload
# sudo systemctl enable --now ecommerce-agent.service

[Unit]
Description=Ecommerce CS Agent API (uvicorn)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/ecommerce-cs-agent
EnvironmentFile=/opt/ecommerce-cs-agent/.env
Environment=PYTHONPATH=/opt/ecommerce-cs-agent
ExecStart=/opt/ecommerce-cs-agent/.venv/bin/uvicorn apps.api_server:app --host 127.0.0.1 --port 8000 --workers 1
Restart=always
RestartSec=5

# 资源上限可按机器调整
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
